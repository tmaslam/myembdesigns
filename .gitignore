# WordPress core (should not be in repo)
/wp-admin/
/wp-includes/
/wp-content/languages/
/wp-content/upgrade/
/wp-content/upgrade-temp-backup/
/wp-content/cache/

# Sensitive config
wp-config.php

# Logs
error_log
wp-content/error_log
wp-admin/error_log
wp-content/debug.log

# Uploads (media should not be in git, except specific fixed files)
/wp-content/uploads/*
!/wp-content/uploads/amazingcarousel-fix/

# Plugin build artifacts
/wp-content/plugins/*/build/
/wp-content/plugins/*/dist/
/wp-content/plugins/*/vendor/
/wp-content/plugins/*/assets/build/

# Backups
/wp-content/ai1wm-backups/

# Misc
.vscode/
.htaccess
wp-content/.htaccess
wp-content/advanced-cache.php
